{
    // ============================================================
    // 推荐部署方案：Nginx stream SNI 分流 + VLESS XHTTP Reality/CDN
    //
    // 架构：
    //   公网 443 → Nginx stream（ssl_preread）→ SNI 分流
    //     ├── 伪装 SNI（www.apple.com）  → Xray Reality 入站 127.0.0.1:4434
    //     └── 面板/网站 SNI              → Nginx http 入站 127.0.0.1:8443
    //                                         └── /your_path (grpc) → Xray CDN 入站 127.0.0.1:4435
    //
    // 注意：Nginx 启用了 proxy_protocol，Xray 入站须设 acceptProxyProtocol: true
    // ============================================================
    "stats": {},
    "api": {
        "tag": "api",
        "services": [
            "StatsService",
            "HandlerService"
        ]
    },
    "policy": {
        "levels": {
            "0": {
                "statsUserUplink": true,
                "statsUserDownlink": true
            }
        },
        "system": {
            "statsInboundUplink": true,
            "statsInboundDownlink": true,
            "statsOutboundUplink": true,
            "statsOutboundDownlink": true
        }
    },
    "log": {
        "loglevel": "warning",
        "access": "/var/log/xray/access.log",
        "error": "/var/log/xray/error.log"
    },
    "inbounds": [
        // ========== Reality 探测回环：伪装目标 ==========
        // dokodemo 把握手流量转发到真实目标站，使 Reality 握手探测通过
        // 路由规则：伪装域名 → direct，其他来源 → block
        {
            "tag": "dokodemo-in",
            "listen": "127.0.0.1",
            "port": 4431,
            "protocol": "dokodemo-door",
            "settings": {
                // 仅为示例,请勿直接使用
                "address": "www.apple.com",
                "port": 443,
                "network": "tcp"
            },
            "sniffing": {
                "enabled": true,
                "destOverride": [
                    "tls"
                ],
                "routeOnly": true
            }
        },
        // ========== VLESS + XHTTP + Reality ==========
        // Nginx stream 将匹配到伪装 SNI 的流量转到此端口
        // acceptProxyProtocol 对应 Nginx stream 的 proxy_protocol on
        {
            "tag": "vless-xhttp-reality",
            "listen": "127.0.0.1",
            "port": 4434,
            "protocol": "vless",
            "settings": {
                "clients": [
                    {
                        "id": "YOUR_UUID_HERE", // xray uuid
                        "email": "user@example.com"
                    }
                ],
                "decryption": "none"
            },
            "streamSettings": {
                "network": "xhttp",
                "xhttpSettings": {
                    "path": "/your_secret_path", // 建议改为随机路径
                    "mode": "auto"
                },
                "security": "reality",
                "realitySettings": {
                    "target": "127.0.0.1:4431",
                    "xver": 0,
                    "serverNames": [
                        "www.apple.com"
                    ],
                    "privateKey": "YOUR_REALITY_PRIVATE_KEY", // xray x25519 的 PrivateKey
                    "shortIds": [
                        "",
                        "0123456789abcdef"
                    ]
                },
                "sockopt": {
                    "acceptProxyProtocol": true // 对应 Nginx proxy_protocol on
                }
            },
            "sniffing": {
                "enabled": true,
                "destOverride": [
                    "http",
                    "tls",
                    "quic"
                ],
                "routeOnly": false
            }
        },
        // ========== VLESS + XHTTP + CDN ==========
        // 由 Nginx http 层通过 grpc_pass 转入，供 CDN 模式使用
        // decryption 填入 xray vlessenc 生成的 decryption 字段值
        // 客户端 encryption 与此值对应，两端认证方式必须一致
        {
            "tag": "vless-xhttp-cdn",
            "listen": "127.0.0.1",
            "port": 4435,
            "protocol": "vless",
            "settings": {
                "clients": [
                    {
                        "id": "YOUR_UUID_HERE",
                        "email": "user@example.com"
                    }
                ],
                "decryption": "YOUR_VLESSENC_DECRYPTION_VALUE" // xray vlessenc 输出的 decryption 字段
            },
            "streamSettings": {
                "network": "xhttp",
                "security": "none",
                "xhttpSettings": {
                    "path": "/your_secret_path",
                    "mode": "auto",
                    "extra": {
                        "scMaxEachPostBytes": "500000-1000000",
                        "scMaxBufferedPosts": 30,
                        "scStreamUpServerSecs": "20-80",
                        "xPaddingBytes": "100-1000"
                    }
                }
            },
            "sniffing": {
                "enabled": true,
                "destOverride": [
                    "http",
                    "tls",
                    "quic"
                ],
                "routeOnly": false
            }
        },
        // ========== API 入站：面板 gRPC 通信专用 ==========
        {
            "tag": "api",
            "listen": "127.0.0.1",
            "port": 10085,
            "protocol": "dokodemo-door",
            "settings": {
                "address": "127.0.0.1"
            }
        }
    ],
    "outbounds": [
        {
            "protocol": "freedom",
            "tag": "direct"
        },
        {
            "protocol": "blackhole",
            "tag": "block"
        }
        // 如需 Warp 或其他出站，在此追加并补充对应路由规则
    ],
    "routing": {
        "domainStrategy": "IPIfNonMatch",
        "rules": [
            // API 流量内部路由
            {
                "type": "field",
                "inboundTag": [
                    "api"
                ],
                "outboundTag": "api"
            },
            // dokodemo 探测流量：伪装目标域名放行，其余全 block
            // 防止探测入站被滥用作代理
            {
                "type": "field",
                "inboundTag": [
                    "dokodemo-in"
                ],
                "domain": [
                    "www.apple.com"
                ],
                "outboundTag": "direct"
            },
            {
                "type": "field",
                "inboundTag": [
                    "dokodemo-in"
                ],
                "outboundTag": "block"
            },
            // 阻断私有 IP 访问（防止 SSRF）
            {
                "type": "field",
                "ip": [
                    "geoip:private"
                ],
                "outboundTag": "block"
            },
            // 屏蔽 BT 流量
            {
                "type": "field",
                "protocol": [
                    "bittorrent"
                ],
                "outboundTag": "block"
            }
        ]
    }
}